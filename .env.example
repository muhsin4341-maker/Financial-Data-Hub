# ── APPLICATION ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=                      # 64-char random hex — generate: openssl rand -hex 32

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fdh:fdh_password@localhost:5432/fdh
DATABASE_URL_SYNC=postgresql://fdh:fdh_password@localhost:5432/fdh   # Alembic (sync)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER_URL=redis://localhost:6379/1
REDIS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
JWT_SECRET=                      # 64-char random hex — generate: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=               # Use 'test' for LocalStack local dev
AWS_SECRET_ACCESS_KEY=           # Use 'test' for LocalStack local dev
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566   # LocalStack — remove for production

# ── S3 BUCKETS ────────────────────────────────────────────────────────────────
S3_DOCUMENTS_BUCKET=fdh-documents-dev
S3_EXPORTS_BUCKET=fdh-exports-dev
S3_ASSETS_BUCKET=fdh-assets-dev

# ── EMAIL ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=console            # console | resend | ses
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Financial Data Hub
EMAIL_RATE_LIMIT_PER_HOUR=10
AWS_SES_REGION=us-east-1
RESEND_API_KEY=                  # Only needed when EMAIL_BACKEND=resend

# ── AI / CLAUDE ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=                  # Anthropic API key
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
CLAUDE_REQUESTS_PER_MINUTE=10

# ── CELERY ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_UNAUTHENTICATED=20       # requests per minute per IP
RATE_LIMIT_FREE_TIER=60
RATE_LIMIT_PRO_TIER=300
RATE_LIMIT_ENTERPRISE_TIER=1000

# ── EXTERNAL SOURCES ──────────────────────────────────────────────────────────
EDGAR_USER_AGENT=FinancialDataHub contact@yourdomain.com   # REQUIRED by SEC
EDGAR_REQUESTS_PER_SECOND=10
EDGAR_BASE_URL=https://efts.sec.gov

# ── EXPORT ───────────────────────────────────────────────────────────────────
EXPORT_SIGNED_URL_EXPIRY_SECONDS=86400   # 24 hours
EXPORT_FILE_RETENTION_DAYS=30
DOCUMENT_FILE_RETENTION_DAYS=730         # 2 years

# ── MONITORING ────────────────────────────────────────────────────────────────
SENTRY_DSN=                      # Leave blank to disable Sentry
PROMETHEUS_METRICS_PORT=9090

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
